<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/namazym_widget_background">

  <ImageView
    android:layout_width="188dp"
    android:layout_height="188dp"
    android:layout_gravity="top|end"
    android:layout_marginTop="-66dp"
    android:layout_marginEnd="-50dp"
    android:alpha="0.58"
    android:background="@drawable/namazym_widget_glow_gold"
    android:contentDescription="@null"
    android:importantForAccessibility="no" />

  <ImageView
    android:layout_width="170dp"
    android:layout_height="170dp"
    android:layout_gravity="bottom|start"
    android:layout_marginStart="-66dp"
    android:layout_marginBottom="-68dp"
    android:alpha="0.34"
    android:background="@drawable/namazym_widget_glow_rose"
    android:contentDescription="@null"
    android:importantForAccessibility="no" />

  <ImageView
    android:layout_width="88dp"
    android:layout_height="88dp"
    android:layout_gravity="top|end"
    android:layout_marginTop="54dp"
    android:layout_marginEnd="18dp"
    android:alpha="0.16"
    android:contentDescription="@null"
    android:importantForAccessibility="no"
    android:scaleType="fitCenter"
    android:src="@drawable/camel_widget" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/widget_city"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:letterSpacing="0.02"
        android:maxLines="1"
        android:text="Aşgabat"
        android:textSize="14sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widget_remaining_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/namazym_widget_chip"
        android:maxLines="1"
        android:paddingHorizontal="10dp"
        android:paddingVertical="5dp"
        android:text="1 sag 36 min"
        android:textSize="11sp"
        android:textStyle="bold" />
    </LinearLayout>

    <TextView
      android:id="@+id/widget_featured"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="9dp"
      android:ellipsize="end"
      android:fontFamily="serif"
      android:letterSpacing="0.03"
      android:maxLines="1"
      android:shadowColor="#66000000"
      android:shadowDx="0"
      android:shadowDy="2"
      android:shadowRadius="4"
      android:text="Agşam • 20:27"
      android:textSize="21sp"
      android:textStyle="bold" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="2dp"
      android:layout_marginTop="8dp"
      android:background="@drawable/namazym_widget_separator"
      android:text="" />

    <GridLayout
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_marginTop="6dp"
      android:layout_weight="1"
      android:alignmentMode="alignMargins"
      android:columnCount="3"
      android:rowCount="2"
      android:useDefaultMargins="true">

      <LinearLayout
        android:id="@+id/prayer_0_cell"
        style="@style/NamazymWidgetPrayerCell"
        android:background="@drawable/namazym_widget_lens_pill">
        <TextView android:id="@+id/prayer_0_label" style="@style/NamazymWidgetPrayerLabel" />
        <TextView android:id="@+id/prayer_0_time" style="@style/NamazymWidgetPrayerTime" />
      </LinearLayout>
      <LinearLayout
        android:id="@+id/prayer_1_cell"
        style="@style/NamazymWidgetPrayerCell"
        android:background="@drawable/namazym_widget_lens_pill">
        <TextView android:id="@+id/prayer_1_label" style="@style/NamazymWidgetPrayerLabel" />
        <TextView android:id="@+id/prayer_1_time" style="@style/NamazymWidgetPrayerTime" />
      </LinearLayout>
      <LinearLayout
        android:id="@+id/prayer_2_cell"
        style="@style/NamazymWidgetPrayerCell"
        android:background="@drawable/namazym_widget_lens_pill">
        <TextView android:id="@+id/prayer_2_label" style="@style/NamazymWidgetPrayerLabel" />
        <TextView android:id="@+id/prayer_2_time" style="@style/NamazymWidgetPrayerTime" />
      </LinearLayout>
      <LinearLayout
        android:id="@+id/prayer_3_cell"
        style="@style/NamazymWidgetPrayerCell"
        android:background="@drawable/namazym_widget_lens_pill">
        <TextView android:id="@+id/prayer_3_label" style="@style/NamazymWidgetPrayerLabel" />
        <TextView android:id="@+id/prayer_3_time" style="@style/NamazymWidgetPrayerTime" />
      </LinearLayout>
      <LinearLayout
        android:id="@+id/prayer_4_cell"
        style="@style/NamazymWidgetPrayerCell"
        android:background="@drawable/namazym_widget_lens_pill">
        <TextView android:id="@+id/prayer_4_label" style="@style/NamazymWidgetPrayerLabel" />
        <TextView android:id="@+id/prayer_4_time" style="@style/NamazymWidgetPrayerTime" />
      </LinearLayout>
      <LinearLayout
        android:id="@+id/prayer_5_cell"
        style="@style/NamazymWidgetPrayerCell"
        android:background="@drawable/namazym_widget_lens_pill">
        <TextView android:id="@+id/prayer_5_label" style="@style/NamazymWidgetPrayerLabel" />
        <TextView android:id="@+id/prayer_5_time" style="@style/NamazymWidgetPrayerTime" />
      </LinearLayout>
    </GridLayout>
  </LinearLayout>
</FrameLayout>
