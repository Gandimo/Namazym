<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/namazym_widget_background">

  <ImageView
    android:layout_width="132dp"
    android:layout_height="132dp"
    android:layout_gravity="bottom|end"
    android:layout_marginEnd="14dp"
    android:layout_marginBottom="16dp"
    android:alpha="0.1"
    android:contentDescription="@null"
    android:importantForAccessibility="no"
    android:scaleType="fitCenter"
    android:src="@drawable/camel_widget" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/widget_city"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Aşgabat"
        android:textSize="14sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widget_remaining_chip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/namazym_widget_chip"
        android:maxLines="1"
        android:paddingHorizontal="10dp"
        android:paddingVertical="5dp"
        android:text="1 sag 36 min"
        android:textSize="11sp"
        android:textStyle="bold" />
    </LinearLayout>

    <TextView
      android:id="@+id/widget_section_title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="18dp"
      android:letterSpacing="0.12"
      android:text="GÜNÜŇ AÝATY"
      android:textSize="12sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_verse"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_marginTop="12dp"
      android:layout_weight="1"
      android:ellipsize="end"
      android:lineSpacingExtra="3dp"
      android:maxLines="4"
      android:text="Rebbiňiz aýtdy: Maňa doga ediň, Men size jogap bereýin."
      android:textSize="18sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/widget_reference"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:gravity="end"
      android:maxLines="1"
      android:text="Mumin, 60"
      android:textSize="13sp"
      android:textStyle="bold" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:layout_marginTop="12dp"
      android:background="@drawable/namazym_widget_separator"
      android:text="" />

    <TextView
      android:id="@+id/widget_footer"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="10dp"
      android:ellipsize="end"
      android:maxLines="1"
      android:text="Agşam • 20:27"
      android:textSize="12sp" />
  </LinearLayout>
</FrameLayout>
