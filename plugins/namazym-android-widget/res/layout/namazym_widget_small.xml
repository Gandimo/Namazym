<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:padding="14dp">

  <TextView
    android:id="@+id/widget_city"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:ellipsize="end"
    android:fontFamily="sans"
    android:maxLines="1"
    android:text="Aşgabat"
    android:textSize="12sp"
    android:textStyle="bold" />

  <TextView
    android:layout_width="1dp"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:text="" />

  <TextView
    android:id="@+id/widget_prayer_label"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:maxLines="1"
    android:text="Ikindi"
    android:textSize="15sp"
    android:textStyle="bold" />

  <TextView
    android:id="@+id/widget_remaining"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:autoSizeMaxTextSize="30sp"
    android:autoSizeMinTextSize="20sp"
    android:autoSizeStepGranularity="1sp"
    android:autoSizeTextType="uniform"
    android:gravity="center"
    android:maxLines="1"
    android:text="1 sag 36 min"
    android:textSize="30sp"
    android:textStyle="bold" />

  <TextView
    android:layout_width="1dp"
    android:layout_height="0dp"
    android:layout_weight="1"
    android:text="" />

  <TextView
    android:id="@+id/widget_next_pill"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/namazym_widget_pill"
    android:ellipsize="end"
    android:gravity="center"
    android:maxLines="1"
    android:paddingHorizontal="10dp"
    android:paddingVertical="6dp"
    android:text="Agşam 20:27"
    android:textSize="12sp"
    android:textStyle="bold" />
</LinearLayout>
